PORT=3001

# Cloudinary
CLOUDINARY_URL=cloudinary://replace-me

# Firebase (service account JSON should be a single line or base64-encoded)
GOOGLE_APPLICATION_CREDENTIALS=base64-encoded-firebase-service-account-json
FIREBASE_PROJECT_ID=replace-me
FIREBASE_DATABASE_URL=https://replace-me.firebaseio.com

# OpenAI
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EXTRACT_MODEL=gpt-4o-mini
OPENAI_FINAL_MODEL=gpt-4o-mini

# OpenRouter
OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EXTRACT_MODEL=openrouter/free
OPENROUTER_FINAL_MODEL=openrouter/free

# NVIDIA
NVIDIA_API_KEY=replace-me
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EXTRACT_MODEL=nvidia/llama-3.1-nemotron-nano-vl-8b-v1
NVIDIA_FINAL_MODEL=nvidia/llama-3.1-nemotron-51b-instruct
